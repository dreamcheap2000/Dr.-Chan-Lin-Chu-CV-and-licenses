
{
    "name": "Full_minus_context_WD",
    "ablation": true,
    "run_config": {
        "data_folders": ["data/WD/train/"],
        "result_folders": ["output/prediction/WD"],
        "model_folders": ["output/trained_model/WD"],
        "test_data_folder": "data/WD/test",
        "test_text_file": "data/WD/test/test_sentence_expert.csv"
    },
    "model_config":  {
        "labels": ["Sample Size", "Population","Intervention"],
        "num_filters": 20, 
        "kernel_sizes": [1,3,5,7,9],
        "sentence_mask": true,
        "distance":"l2", 
        "learning_rate":3e-5,
        "patience":8, 
        "tag_cost_weight": 0.5, 
        "tagging": true,
        "att_projection_layer": "lstm", 
        "att_hidden_dim": 100,
        "att_dropout_rate": 0.3,
        "text_projection_layer": "linear", 
        "text_hidden_dim": 100,
        "initial_weights": [2.0,1.0,1.0],
        "use_context": false,
        "use_fragment": true,
        "enable_frag_att": true,
        "enable_joint_learning": true,
        "tagging_method":"fastsr",
        "syn_cost": true
    }
}